# App
APP_NAME=ContractFlow
DEBUG=true
SECRET_KEY=your-super-secret-key-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/contractflow

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# AWS S3 (optional - uses local mock if not set)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
S3_BUCKET_NAME=contractflow-docs

# Anthropic Claude API (optional - uses mock if not set)
ANTHROPIC_API_KEY=
